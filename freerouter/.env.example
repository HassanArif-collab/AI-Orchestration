# FreeRouter v4.0 Environment Configuration
# 6 providers with deep fallback chains
# Copy this file to .env and fill in your API keys

# =============================================================================
# Provider 1: Ollama Cloud (PRIMARY — no rate limits, no geo-block)
# =============================================================================
OLLAMA_API_KEY=
OLLAMA_API_BASE=https://ollama.com

# =============================================================================
# Provider 2: Google AI Studio (Gemma 4 31B — 15 req/min, 1.5K req/day)
# =============================================================================
GOOGLE_API_KEY=

# =============================================================================
# Provider 3: Zhipu AI (GLM-4.7 — reliable, high rate limits)
# =============================================================================
ZHIPU_API_KEY=

# =============================================================================
# Provider 4: OpenRouter (Free tier — 20 req/min shared)
# =============================================================================
OPENROUTER_API_KEY=
