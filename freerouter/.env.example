# FreeRouter Environment Configuration
# Copy this file to .env and fill in your API keys

# =============================================================================
# REQUIRED API KEYS (at least one for full functionality)
# =============================================================================

# OpenRouter API Key - Provides access to many free models
# Get it from: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Groq API Key - Fast inference with free tier
# Get it from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# =============================================================================
# OPTIONAL API KEYS (enable additional providers)
# =============================================================================

# Anthropic API Key - For Claude models (paid)
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI API Key - For GPT models (paid)
# OPENAI_API_KEY=your_openai_api_key_here

# Together.ai API Key - Some free models available
# TOGETHER_AI_API_KEY=your_together_api_key_here

# DeepInfra API Key - Pay-per-use, very cheap
# DEEPINFRA_API_KEY=your_deepinfra_api_key_here

# =============================================================================
# FREEROUTER SETTINGS
# =============================================================================

# Optional: Set a custom config file path
# FREEROUTER_CONFIG=/path/to/config.yaml

# Optional: Set a master API key for the proxy itself
# This protects your proxy from unauthorized access
# FREEROUTER_API_KEY=your_freerouter_key_here

# =============================================================================
# LITELLM SETTINGS
# =============================================================================

# Set to true for verbose logging
# LITELLM_SET_VERBOSE=true

# Database URL for cost tracking (optional)
# Uses SQLite by default if set
# DATABASE_URL=sqlite:///./freerouter.db

# =============================================================================
# OLLAMA SETTINGS (for local models)
# =============================================================================

# Ollama API base URL (default: http://localhost:11434)
# OLLAMA_API_BASE=http://localhost:11434

# =============================================================================
# EXAMPLE: Using with Claude Code
# =============================================================================
# Set these environment variables to use FreeRouter with Claude Code:
#
# ANTHROPIC_BASE_URL=http://localhost:4000
# ANTHROPIC_API_KEY=your_freerouter_key_here  # Or any value if no key set
#
# Then Claude Code will route through FreeRouter automatically!