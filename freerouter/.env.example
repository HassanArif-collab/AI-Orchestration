# FreeRouter Environment Configuration
# Copy this file to .env and fill in your API keys
# At least one provider must be configured for the system to work

# =============================================================================
# FREE TIER PROVIDERS (Recommended - Start Here)
# =============================================================================

# OpenRouter API Key - Many free models available
# Get it from: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Groq API Key - Fast inference with generous free tier
# Get it from: https://console.groq.com/keys
GROQ_API_KEY=

# Mistral AI API Key - Free tier available
# Get it from: https://console.mistral.ai/
MISTRAL_API_KEY=

# Together AI API Key - Free tier available
# Get it from: https://api.together.ai/settings/api-keys
TOGETHER_API_KEY=

# SambaNova API Key - Free tier available
# Get it from: https://cloud.sambanova.ai/
SAMBANOVA_API_KEY=

# Cerebras API Key - Fast inference, free tier
# Get it from: https://cloud.cerebras.ai/
CEREBRAS_API_KEY=

# GitHub Token - For GitHub Models (free tier)
# Get it from: https://github.com/settings/tokens
# Requires 'models:read' scope
GITHUB_TOKEN=

# APIFreeLLM API Key - Completely free with 25s rate limit
# Get it from: https://apifreellm.com/en/api-access
APIFREELLM_API_KEY=

# Z.AI API Key - GLM models
# Get it from: https://docs.z.ai/
ZAI_API_KEY=

# =============================================================================
# LOCAL PROVIDER (No API key needed)
# =============================================================================

# Ollama API base URL (default: http://localhost:11434)
# Install Ollama from: https://ollama.ai
OLLAMA_BASE_URL=http://localhost:11434/v1

# =============================================================================
# PAID PROVIDERS (Optional fallbacks)
# =============================================================================

# DeepInfra API Key - Pay-per-use, very cheap
# Get it from: https://deepinfra.com/dash
# DEEPINFRA_API_KEY=

# OpenAI API Key - For GPT models
# Get it from: https://platform.openai.com/api-keys
# OPENAI_API_KEY=

# Anthropic API Key - For Claude models
# Get it from: https://console.anthropic.com/account/keys
# ANTHROPIC_API_KEY=

# =============================================================================
# YOUTUBE API (For Trend Analysis)
# =============================================================================

# YouTube Data API v3 Key - For getting trending videos
# Get it from: https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=

# YouTube Analytics API (OAuth) - For analyzing your channel
# Get it from: https://console.cloud.google.com/apis/credentials
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# =============================================================================
# NOTION INTEGRATION (For Output)
# =============================================================================

# Notion API Key - For publishing scripts
# Get it from: https://www.notion.so/profile/integrations
NOTION_API_KEY=

# Notion Database ID - Where to save scripts
NOTION_DATABASE_ID=

# =============================================================================
# FREEROUTER SETTINGS
# =============================================================================

# Optional: Set a master API key for the proxy itself
# This protects your proxy from unauthorized access
# FREEROUTER_API_KEY=

# Set to true for verbose logging
# LITELLM_SET_VERBOSE=true

# Database URL for cost tracking (optional)
# Uses SQLite by default if set
# DATABASE_URL=sqlite:///./freerouter.db

# =============================================================================
# EXAMPLE: Using with Claude Code
# =============================================================================
# Set these environment variables to use FreeRouter with Claude Code:
#
# ANTHROPIC_BASE_URL=http://localhost:4000
# ANTHROPIC_API_KEY=your_freerouter_key_here
#
# Then Claude Code will route through FreeRouter automatically!
