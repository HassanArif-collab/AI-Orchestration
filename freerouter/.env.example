# FreeRouter v3.1 Environment Configuration
# 3 providers: OpenRouter (primary), Groq (fast loops), Ollama Cloud (creative backup)
# Copy this file to .env and fill in your API keys

# =============================================================================
# REQUIRED — Provider API Keys
# =============================================================================

# OpenRouter API Key — used by: auto, researcher, topic_finder, script_writer
# Get it from: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Groq API Key — used by: scorer, challenger, annotator
# Get it from: https://console.groq.com/keys
GROQ_API_KEY=

# Ollama Cloud API Key — used by: topic_finder, researcher (fallbacks)
# Get it from: https://ollama.com/settings/api-keys
OLLAMA_API_KEY=

# =============================================================================
# OPTIONAL — Provider Base URLs
# =============================================================================

# Ollama Cloud base URL (default: https://ollama.com)
# Use https://ollama.com for Ollama Cloud, or http://localhost:11434 for local
OLLAMA_API_BASE=https://ollama.com
