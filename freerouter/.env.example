# FreeRouter v3 Environment Configuration
# Copy this file to .env and fill in your API keys

# =============================================================================
# REQUIRED - Free tier API keys
# =============================================================================

# OpenRouter API Key - Get it from: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Groq API Key - Get it from: https://console.groq.com/keys
GROQ_API_KEY=

# =============================================================================
# OPTIONAL - Local models via Ollama
# =============================================================================

# Ollama API base URL (default: http://localhost:11434)
# Install Ollama from: https://ollama.ai
OLLAMA_BASE_URL=http://localhost:11434/v1
