# Python
__pycache__/
*.py[cod]
*$py.class
*.pyo
.Python

# Virtual environments
venv/
.venv/
env/

# Build artifacts — never commit these
*.egg-info/
dist/
build/

# Environment files — CRITICAL: real keys must never be committed
.env
freerouter/.env
# Allow example/template files (no real keys)
!.env.example
!freerouter/.env.example

# SQLite databases — runtime data, not source code
*.db
*.db-shm
*.db-wal

# Runtime outputs — generated by pipeline, not source code
packages/data/synthesis_reports/
packages/data/*.jsonl
scripts/generated/
freerouter/data/

# Logs
*.log
web.log
start.log
web_err.log
start_err.log

# AI tool configs — auto-generated, not hand-written source
.zencoder/
.zenflow/

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# FreeRouter specific
freerouter/state/
config/local_config.yaml
