# YouTube Pipeline Configuration
# Copy this file to .env at the repo root and fill in your values.
#
# NOTE: FreeRouter has its OWN .env at freerouter/.env for provider API keys
# (GROQ_API_KEY, OPENROUTER_API_KEY etc.). That is managed via the FreeRouter
# web dashboard at http://localhost:8080.
# This file is ONLY for the pipeline packages (Zep, YouTube, Notion, etc.)

# ─── FreeRouter Proxy ────────────────────────────────────────────────────────
# The LLM gateway. Must be running: python -m freerouter proxy
# Default is correct if running locally.
FREEROUTER_URL=http://localhost:4000

# ─── GetZep Cloud (agent memory) ─────────────────────────────────────────────
# Free tier: https://app.getzep.com
ZEP_API_KEY=
ZEP_BASE_URL=https://api.getzep.com

# ─── YouTube Data API v3 ─────────────────────────────────────────────────────
# https://console.cloud.google.com → Enable YouTube Data API v3
YOUTUBE_API_KEY=

# ─── Notion API ──────────────────────────────────────────────────────────────
# https://www.notion.so/my-integrations
NOTION_API_KEY=
# Database ID for script pages (from the Notion database URL)
# e.g., https://www.notion.so/myworkspace/a8aec43384f447ed84290e2
NOTION_DATABASE_ID=

# ─── GitHub (optional, for code agent commits) ───────────────────────────────
GITHUB_TOKEN=

# ─── Supabase (Postgres DB + Realtime for agent thoughts) ────────────────────
# Get credentials from: https://app.supabase.com/project/_/settings/api
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Exa.ai (AI-Native Web Search for Topic Discovery) ───────────────────────
# Get your API key from: https://dashboard.exa.ai/api-keys
# Free tier: 1000 searches/month
EXA_API_KEY=

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ─── Feature Flags (pause pipeline stages) ───────────────────────────────────
# Set to false to skip asset creation (Remotion renders, shader backgrounds)
ASSET_CREATION_ENABLED=true
# Set to false to skip publishing (Notion pages, YouTube upload prep)
PUBLISH_ENABLED=true
