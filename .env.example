# YouTube Pipeline Configuration
# Copy this file to .env at the repo root and fill in your values.
#
# NOTE: FreeRouter has its OWN .env at freerouter/.env for provider API keys
# (GROQ_API_KEY, OPENROUTER_API_KEY etc.). That is managed via the FreeRouter
# web dashboard at http://localhost:8080.
# This file is ONLY for the pipeline packages (Zep, YouTube, Notion, etc.)

# ─── FreeRouter Proxy ────────────────────────────────────────────────────────
# The LLM gateway. Must be running: python -m freerouter proxy
# Default is correct if running locally.
FREEROUTER_URL=http://localhost:4000

# ─── Supabase (REST API + Postgres DB) ───────────────────────────────────────
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
# SUPABASE_URL is the "Project URL"
SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY is the "anon / public" key (safe for frontend, RLS enforced)
SUPABASE_ANON_KEY=eyJ...
# SUPABASE_SERVICE_ROLE_KEY is the "service_role" key (backend only, bypasses RLS)
# NEVER expose this to the frontend or commit it to version control
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# SUPABASE_DB_URL - Direct PostgreSQL connection (REQUIRED for LangGraph checkpointer)
# Find this in: Supabase Dashboard → Settings → Database → Connection string → URI
# Use Session mode (port 5432), NOT Transaction mode (port 6543)
# Format: postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres?sslmode=require
SUPABASE_DB_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres?sslmode=require

# ─── GetZep Cloud (agent memory) ─────────────────────────────────────────────
# Free tier: https://app.getzep.com
ZEP_API_KEY=
ZEP_BASE_URL=https://api.getzep.com

# ─── YouTube Data API v3 ─────────────────────────────────────────────────────
# https://console.cloud.google.com → Enable YouTube Data API v3
YOUTUBE_API_KEY=

# ─── YouTube Analytics API (OAuth2) ─────────────────────────────────────────
# REQUIRED for YouTube Analytics tests (test_get_channel_analytics, test_analyze_content_gaps)
# Setup guide:
#   1. Google Cloud Console → APIs & Services → Credentials
#   2. Create OAuth 2.0 Client ID (Web application type)
#   3. Add http://localhost:8000 as Authorized JavaScript Origin
#   4. Add https://developers.google.com/oauthplayground as Authorized Redirect URI
#   5. Go to https://developers.google.com/oauthplayground
#   6. Select YouTube Analytics API v2 scopes → Authorize → Exchange for refresh token
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# ─── Notion API ──────────────────────────────────────────────────────────────
# https://www.notion.so/my-integrations
NOTION_API_KEY=
# Database ID for script pages (from the Notion database URL)
# e.g., https://www.notion.so/myworkspace/a8aec43384f447ed84290e2
NOTION_DATABASE_ID=

# ─── GitHub (optional, for code agent commits) ───────────────────────────────
GITHUB_TOKEN=

# ─── Exa.ai (AI-Native Web Search for Topic Discovery) ───────────────────────
# Get your API key from: https://dashboard.exa.ai/api-keys
# Free tier: 1000 searches/month
EXA_API_KEY=

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ─── LiteLLM ─────────────────────────────────────────────────────────────────
# Prevents LiteLLM from making a blocking HTTP call to GitHub at import time
# to fetch model pricing data. Uses the bundled local copy instead.
LITELLM_LOCAL_MODEL_COST_MAP=True

# ─── Feature Flags (pause pipeline stages) ───────────────────────────────────
# Set to false to skip asset creation (Remotion renders, shader backgrounds)
ASSET_CREATION_ENABLED=true
# Set to false to skip publishing (Notion pages, YouTube upload prep)
PUBLISH_ENABLED=true
